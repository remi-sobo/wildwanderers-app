# Wild Wanderers Platform — environment variables
# Copy to .env.local and fill with real values. Never commit .env.local.
# Grouped by the ring that first needs them.

# --- Ring 0: Supabase + app ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server only, never exposed to the browser
NEXT_PUBLIC_APP_URL=https://app.wildwanderers.life

# --- Ring 1: email ---
RESEND_API_KEY=

# --- Ring 2: nutrition data + voice ---
NUTRITION_API_KEY=                  # provider chosen at Ring 2
DEEPGRAM_API_KEY=                   # voice check-ins

# --- Ring 3: Coach AI ---
ANTHROPIC_API_KEY=

# --- Ring 4: payments (business switch) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
